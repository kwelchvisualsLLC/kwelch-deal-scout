# --- KWelch Deal Scout configuration ---

# REQUIRED for the AI features (discovery, outreach, profile fit, leads).
# Get one at https://console.anthropic.com  → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL. Port the backend listens on (default 8787).
PORT=8787

# OPTIONAL. Live Instagram stats via a RapidAPI Instagram scraper.
# Leave blank to use manually-entered / known stats (the app works fine without it).
# 1. Subscribe to an Instagram scraper on https://rapidapi.com (e.g. "instagram-scraper-api2")
# 2. Paste your X-RapidAPI-Key below and set the host you subscribed to.
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram-scraper-api2.p.rapidapi.com
